rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if true;
    }

    match /services/{serviceId} {
      allow read, write: if true;
    }

    match /orders/{orderId} {
      allow read, write: if true;
    }

    match /payments/{paymentId} {
      allow read, write: if true;
    }

    match /referrals/{referralId} {
      allow read, write: if true;
    }
  }
}
